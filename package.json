{
  "name": "vite-react-typescript-starter",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:check": "tsc -b --watch",
    "dev:full": "concurrently \"npm run dev\" \"npm run lint:watch\"",
    "build": "npm run lint && npm run typecheck && vite build",
    "typecheck": "tsc -b",
    "lint": "eslint . --max-warnings 50",
    "lint:fix": "eslint . --fix",
    "lint:watch": "nodemon --exec \"npm run lint\" --watch src --ext ts,tsx",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.87.4",
    "@types/react-router-dom": "^5.3.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "nodemon": "^3.1.10",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.24.1",
    "vite": "^6.2.0",
    "vite-plugin-checker": "^0.10.3"
  }
}
